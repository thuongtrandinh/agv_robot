#include <mainpp.h>
#include <std_msgs/Int32.h>
#include <stdio.h>
#include <data_struct.h>
#include "imu_data_struct.h"
#include "motor_data_struct.h"
#include "geometry_msgs/Twist.h"
#include <sensor_msgs/Imu.h>

uint32_t current_time = 0, previous_time = 0;
ros::NodeHandle nh;

struct imu_data imu_data_tx;
struct motor_data motor_data_tx;
extern float setpoint_left, setpoint_right;
extern float duty_left, duty_right;
extern float speed_left, speed_right;
extern float wheel_base;

// Publisher
std_msgs::String str_msg;
sensor_msgs::Imu imu;
geometry_msgs::Twist vel_msg;
geometry_msgs::Twist vol_msg;


// Motor state messages
void subscriber_cmd_callback(const geometry_msgs::Twist& data);
void compute_setpoint_speed(void);
void publisher_voltage(void);

char Str_forward[] = "hehe";
//ros::Publisher chatter("chatter", &str_msg);
ros::Publisher imu_pub("imu", &imu);
ros::Publisher vel_pub("vel_pub", &vel_msg);
//ros::Publisher vol_pub("vol_pub", &vol_msg);

ros::Subscriber<geometry_msgs::Twist> cmd_vel_sub("cmd_vel", &subscriber_cmd_callback);
// Callback for UART transmission complete
void HAL_UART_TxCpltCallback(UART_HandleTypeDef *huart) {
   nh.getHardware()->flush();
}
// Callback for UART reception complete
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
   nh.getHardware()->reset_rbuf();
}
void setup(void) {
   nh.initNode();
   nh.subscribe(cmd_vel_sub);
   //nh.advertise(chatter);
   nh.advertise(imu_pub);
   nh.advertise(vel_pub);
//   nh.advertise(vol_pub);
}
void loop(void) {
		vel_msg.linear.x  = vel_data_tx.v;
		vel_msg.angular.z = vel_data_tx.w;
		vel_pub.publish(&vel_msg);
		str_msg.data = Str_forward;
		//chatter.publish(&str_msg);

		imu.linear_acceleration.x=imu_data_tx.x;
		imu.linear_acceleration.y=imu_data_tx.y;
		imu.linear_acceleration.z=imu_data_tx.z;

		imu.angular_velocity.x=motor_data_tx.left;
		imu.angular_velocity.y=motor_data_tx.right;

		imu.orientation.x=imu_data_tx.x;
		imu.orientation.y=imu_data_tx.y;
		imu.orientation.z=imu_data_tx.z;
		imu_pub.publish(&imu);
		nh.spinOnce();
		//HAL_Delay(10); // Add a delay for stability
}

void subscriber_cmd_callback(const geometry_msgs::Twist& data){
	vel_data_rx.v = data.linear.x;
	vel_data_rx.w = data.angular.z;
   compute_setpoint_speed();
}
void compute_setpoint_speed(){
	setpoint_left = vel_data_rx.v - vel_data_rx.w*wheel_base/2;
	setpoint_right = vel_data_rx.v + vel_data_rx.w*wheel_base/2;
}
