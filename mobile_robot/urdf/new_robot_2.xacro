<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<!--matierials.xacro-->
	<material name="black">
		<color rgba="0.0 0.0 0.0 1.0"/>
	</material>

	<material name="blue">
		<color rgba="0.0 0.0 0.8 1.0"/>
	</material>

	<material name="green">
		<color rgba="0.0 0.8 0.0 1.0"/>
	</material>

	<material name="grey">
		<color rgba="0.2 0.2 0.2 1.0"/>
	</material>

	<material name="orange">
		<color rgba="${255/255} ${108/255} ${10/255} 1.0"/>
	</material>

	<material name="brown">
		<color rgba="${222/255} ${207/255} ${195/255} 1.0"/>
	</material>

	<material name="red">
		<color rgba="0.8 0.0 0.0 1.0"/>
	</material>

	<material name="white">
		<color rgba="1.0 1.0 1.0 1.0"/>
	</material>

	<material name="yellow" >
    	<color rgba="1.0 1.0 0.0784313725490196 1.0" />
	</material>

	<material name="stainless">
		<color rgba="${224/255} ${223/255} ${219/255} 1.0"/>
	</material>

	<material name="aluminium">
		<color rgba="${132/255} ${135/255} ${137/255} 1.0"/>
	</material>
	    
<!--define physical properties for robot-->
	<xacro:property name="robot_mass" value="4"/>
	<xacro:property name="body_length" value="0.3"/>
	<xacro:property name="body_width" value="0.4"/>
	<xacro:property name="body_height" value="0.3"/>
	<xacro:property name="body_mass" value="15"/>
	
	<!-- Frame structure properties (20x20cm grid) -->
	<xacro:property name="frame_beam_radius" value="0.008"/>
	<xacro:property name="frame_beam_mass" value="0.2"/>
	<xacro:property name="frame_beam_20" value="0.02"/>
	<xacro:property name="frame_beam_40" value="0.04"/>
	<xacro:property name="mica_sheet_thickness" value="0.005"/>
	<xacro:property name="mica_mass" value="0.2"/>
	    	    
	<xacro:property name="wheel_radius" value="0.05"/>
	<xacro:property name="wheel_width" value="0.03"/>
	<xacro:property name="wheel_mass" value="0.3"/>
	<xacro:property name="wheel_separation" value="0.42"/>
	<xacro:property name="PI" value="3.1415926535897931"/>
	    
	<xacro:macro name="cylinder_inertia" params="m r h">
		<inertia ixx="${m*(3*r*r+h*h)/12}" ixy = "0" ixz = "0"
		         iyy="${m*(3*r*r+h*h)/12}" iyz = "0"
		         izz="${m*r*r/2}"/> 
	</xacro:macro>

	<xacro:macro name="box_inertia" params="m l w h">
		<inertia ixx="${m*(h*h+l*l)/12}" ixy = "0" ixz = "0"
		         iyy="${m*(w*w+h*h)/12}" iyz = "0"
		         izz="${m*(w*w+l*l)/12}" /> 
	</xacro:macro>

<!--base link-->
    <joint name="base_footprint_joint" type="fixed">
       	<origin xyz="0.0 0.0 ${wheel_radius}" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <link name="base_footprint">
    	<origin xyz="0.0 0.0 0.0"/>
    </link>
  	
	<link name="base_link">
       	<origin xyz="0.0 0.0 0.0"/>
       	<inertial>
       		<origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
       		<mass value="${robot_mass}"/>
       		<inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
       	</inertial>
    </link>
              
<!--chassis link - Frame Structure with Grid-->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0.0 0.0 0.0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                 <box size="${body_length} ${body_width} ${mica_sheet_thickness}"/>
            </geometry>
            <material name="white"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                 <box size="${body_length} ${body_width} ${mica_sheet_thickness}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${mica_mass}"/>
            <xacro:box_inertia m="${mica_mass}" l="${body_length}" w="${body_width}" h="${mica_sheet_thickness}"/>
        </inertial>
    </link>

    <!-- Vertical support posts (corners) -->
    <!-- Front Left Post -->
    <joint name="post_fl_joint" type="fixed">
        <parent link="base_link"/>
        <child link="post_fl"/>
        <origin xyz="0.15 -0.2 0.15"/>
    </joint>

    <link name="post_fl">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
            <material name="aluminium"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${frame_beam_mass}"/>
            <xacro:box_inertia m="${frame_beam_mass}" l="${frame_beam_20}" w="${frame_beam_20}" h="${body_height}"/>
        </inertial>
    </link>

    <!-- Front Right Post -->
    <joint name="post_fr_joint" type="fixed">
        <parent link="base_link"/>
        <child link="post_fr"/>
        <origin xyz="0.15 0.2 0.15"/>
    </joint>

    <link name="post_fr">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
            <material name="aluminium"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${frame_beam_mass}"/>
            <xacro:box_inertia m="${frame_beam_mass}" l="${frame_beam_20}" w="${frame_beam_20}" h="${body_height}"/>
        </inertial>
    </link>

    <!-- Back Left Post -->
    <joint name="post_bl_joint" type="fixed">
        <parent link="base_link"/>
        <child link="post_bl"/>
        <origin xyz="-0.15 -0.2 0.15"/>
    </joint>

    <link name="post_bl">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
            <material name="aluminium"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${frame_beam_mass}"/>
            <xacro:box_inertia m="${frame_beam_mass}" l="${frame_beam_20}" w="${frame_beam_20}" h="${body_height}"/>
        </inertial>
    </link>

    <!-- Back Right Post -->
    <joint name="post_br_joint" type="fixed">
        <parent link="base_link"/>
        <child link="post_br"/>
        <origin xyz="-0.15 0.2 0.15"/>
    </joint>

    <link name="post_br">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
            <material name="aluminium"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${frame_beam_20} ${frame_beam_20} ${body_height}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${frame_beam_mass}"/>
            <xacro:box_inertia m="${frame_beam_mass}" l="${frame_beam_20}" w="${frame_beam_20}" h="${body_height}"/>
        </inertial>
    </link>

    <!-- Middle vertical posts (20x20cm grid) -->
    <!-- Mica layers at different heights -->
    <!-- Middle Layer -->
    <joint name="layer_middle_joint" type="fixed">
        <parent link="base_link"/>
        <child link="layer_middle"/>
        <origin xyz="0.0 0.0 0.15" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="layer_middle">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                 <box size="${body_length} ${body_width} ${mica_sheet_thickness}"/>
            </geometry>
            <material name="white"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                 <box size="${body_length} ${body_width} ${mica_sheet_thickness}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${mica_mass}"/>
            <xacro:box_inertia m="${mica_mass}" l="${body_length}" w="${body_width}" h="${mica_sheet_thickness}"/>
        </inertial>
    </link>

    <!-- Top Layer -->
    <joint name="layer_top_joint" type="fixed">
        <parent link="base_link"/>
        <child link="layer_top"/>
        <origin xyz="0.0 0.0 0.295" rpy="0.0 0.0 0.0"/>
    </joint>

    <link name="layer_top">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                 <box size="${body_length} ${body_width} ${mica_sheet_thickness}"/>
            </geometry>
            <material name="white"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                 <box size="${body_length} ${body_width} ${mica_sheet_thickness}"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${mica_mass}"/>
            <xacro:box_inertia m="${mica_mass}" l="${body_length}" w="${body_width}" h="${mica_sheet_thickness}"/>
        </inertial>
    </link>
       
<!--right wheel-->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.1 -0.23 -0.02" rpy="${PI/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="right_wheel">
        <visual>
           	<geometry>
             	<cylinder radius="${wheel_radius}" length="${wheel_width}"/>
           	</geometry>
           		<material name="blue"/>
        </visual>

        <collision>
           	<geometry>
             	<cylinder radius="${wheel_radius}" length="${wheel_width}"/>
           	</geometry>
        </collision>

       	<inertial>
            <mass value="${wheel_mass}"/>
            <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
        	</inertial>
    </link>

<!--left wheel-->
	<joint name="left_wheel_joint" type="continuous">
       	<parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.1 0.23 -0.02" rpy="${-PI/2} 0.0 0.0"/>
        <axis xyz="0 0 1"/>
    </joint>

	<link name="left_wheel">
        <visual>
           	<geometry>
             	<cylinder radius="${wheel_radius}" length="${wheel_width}"/>
           	</geometry>
           	<material name="blue"/>
        </visual>

        <collision>
           	<geometry>
             	<cylinder radius="${wheel_radius}" length="${wheel_width}"/>
           	</geometry>
        </collision>

        <inertial>
            <mass value="${wheel_mass}"/>
            <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
        </inertial>
	</link>  
    
<!--caster wheel - free castor at back-->
	<joint name="caster_wheel_joint" type="fixed">
		<parent link="base_link"/>
		<child link="caster_wheel"/>
		<origin xyz="-0.1 0.0 -0.035"/>
	</joint>

	<link name="caster_wheel">
		<visual>
			<geometry>
				<sphere radius="0.035"/>
			</geometry>
			<material name="red"/>
		</visual>

		<collision>
			<geometry>
				<sphere radius="0.035"/>
			</geometry>
		</collision>

		<inertial>
			<mass value="0.08"/>
			<inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
		</inertial>
	</link>

<!--lidar-->
	<joint name="joint_scan" type="fixed">
		<origin xyz="0.0 0.0 0.4" rpy="0 0 0"/>
		<parent link="base_link"/>
		<child link="laser"/>
	</joint>

    <link name="laser">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.04" length="0.03"/>
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.04" length="0.03"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="0.114"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>

	<!-- Thân ZED2 (body) -->
	<link name="zed2_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<!-- 146.5 x 30 x 23 mm -->
				<box size="0.03 0.1465 0.023"/>
			</geometry>
			<material name="grey"/>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<box size="0.03 0.1465 0.023"/>
			</geometry>
		</collision>
		<inertial>
			<mass value="0.5"/>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
		</inertial>
	</link>

	<joint name="zed2_joint" type="fixed">
		<parent link="base_link"/>
		<child link="zed2_link"/>
		<!-- Camera at 15cm from center forward on robot -->
		<origin xyz="0.15 0.0 0.35"/>
	</joint>

	<!-- Left Camera (U26) -->
	<link name="zed2_left_camera_frame"/>
	<joint name="zed2_left_camera_joint" type="fixed">
		<parent link="zed2_link"/>
		<child link="zed2_left_camera_frame"/>
		<!-- 9.3 mm từ mép trái: -0.07325 m so với tâm -->
		<origin xyz="0 -0.07325 0"/>
	</joint>

	<!-- Right Camera (U36) -->
	<link name="zed2_right_camera_frame"/>
	<joint name="zed2_right_camera_joint" type="fixed">
		<parent link="zed2_link"/>
		<child link="zed2_right_camera_frame"/>
		<!-- 129.3 mm từ mép trái: +0.07325 m so với tâm -->
		<origin xyz="0 0.07325 0"/>
	</joint>
	<!--  End ZED2 -->

	<!-- IMU (trên mặt robot, chính giữa thân) -->
    <link name="imu_link"/>
    
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0.0 0.0 0.35" rpy="0 0 0"/>
    </joint>
    <!-- End IMU -->

</robot>
